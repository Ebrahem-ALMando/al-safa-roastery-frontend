# =============================================================================
# Al Safa Roastery — Next.js production template (safe to commit)
# =============================================================================
# Copy values to Vercel Production environment variables.
# Replace FRONTEND_DOMAIN with your deployed frontend hostname.
# =============================================================================

NEXT_PUBLIC_APP_NAME="محمصة الصفا"
NEXT_PUBLIC_APP_URL=https://FRONTEND_DOMAIN
NEXT_PUBLIC_SITE_URL=https://FRONTEND_DOMAIN
NEXT_PUBLIC_MODE=production

NEXT_PUBLIC_API_BASE_URL=https://backend.al-safa.drmahranneuro.cloud/api/v1

LAB_API_BASE_URL=https://backend.al-safa.drmahranneuro.cloud

PDF_RENDER_BASE_URL=https://FRONTEND_DOMAIN

