## Frontend Build Variables (public, safe to expose)
NEXT_PUBLIC_APP_NAME="محمصة الصفا"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_MODE="dev"

# Laravel API v1 (no trailing slash). Used by BFF + /api/auth/* route handlers.
NEXT_PUBLIC_API_BASE_URL="http://127.0.0.1:8000/api/v1"

# Server-side Laravel root (no trailing slash) — verify pages, etc.
LAB_API_BASE_URL="http://127.0.0.1:8000"

# Optional branding overrides
# NEXT_PUBLIC_BRAND_NAME_AR="محمصة الصفا"
# NEXT_PUBLIC_BRAND_NAME_EN="Al Safa Roastery"

# PDF route: defaults to request origin if unset
# PDF_RENDER_BASE_URL="http://localhost:3000"

# Local Chromium for PDF export (Windows example)
# PUPPETEER_EXECUTABLE_PATH="C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe"

## Production template
# See env.production.example for Vercel / production values.
