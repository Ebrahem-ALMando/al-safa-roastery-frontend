## Frontend Build Variables (public, safe to expose)
NEXT_PUBLIC_APP_NAME="نظام إدارة محمصة الصفا"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_MODE="dev"

# NEXT_PUBLIC_API_BASE_URL points to Laravel API v1 (no trailing slash).
# Browser calls should normally use /api/bff.
# Auth uses local /api/auth/* route handlers.
NEXT_PUBLIC_API_BASE_URL="http://127.0.0.1:8000/api/v1"
LAB_API_BASE_URL="http://127.0.0.1:8000"

# يُفضّل للـ BFF (قراءة وقت التشغيل على الخادم)؛ يغلب القيم الأخرى في getLaravelBaseUrl()
BFF_UPSTREAM_API_URL="http://127.0.0.1:8000/api/v1"

## Frontend Runtime Variables (server-side BFF only)
# Include 127.0.0.1 and https variants — CSRF guard matches Origin/Host exactly
BFF_ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,https://localhost:3000,https://127.0.0.1:3000,http://localhost:3001"
BFF_ALLOWED_HOSTS="localhost:3000,127.0.0.1:3000,localhost:3001"
BFF_REFRESH_TOKEN_TTL_DAYS="30"
BFF_COOKIE_ENCRYPTION_KEY="wJALH6s7z9ZmC2Z6wJALH6s7z9ZmC2Z6"
